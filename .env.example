# ==========================================
# GastroSaaS - Ambiente de Produção / Local
# ==========================================

# 1. BANCO DE DADOS (PostgreSQL)
# Conexão principal com o banco de dados Postgres hospedado na VPS.
# No Easypanel, use a URI gerada pelo serviço do Postgres.
DATABASE_URL="postgresql://postgres:0szv1pljii1yiuieaxqc@163.176.184.183:5432/restaurante?sslmode=disable"

# 2. CACHE E FILAS (Redis)
# URL de conexão com o Redis para controle de queues, jobs e cache do SaaS.
REDIS_URL="redis://:sua-senha-segura@vps-ip-ou-domain:6379"

# 3. CONFIGURAÇÕES DO NEXT.JS (APIs & SEGURANÇA)
# URL de produção do frontend (Vercel) ou backend (Easypanel)
NEXT_PUBLIC_API_URL="https://api.seu-dominio.com.br"
NEXT_PUBLIC_APP_URL="https://seu-dominio.com.br"

# Chave secreta de autenticação e criptografia
NEXTAUTH_SECRET="gerar-uma-hash-md5-ou-sha256-bem-segura"

# 4. INTEGRAÇÃO IFOOD (Opcional)
IFOOD_CLIENT_ID="seu-client-id-ifood"
IFOOD_CLIENT_SECRET="seu-client-secret-ifood"
IFOOD_MERCHANT_ID="seu-merchant-id-ifood"

# 5. DOCKER/NODE PORT (Padrão para rodar standalone)
PORT=3000
NODE_ENV=production
